# === LLM Providers ===
# OpenCode Go (ローカル)
OPENCODE_BASE_URL=http://localhost:8080
OPENCODE_API_KEY=sk-dummy
OPENCODE_MODEL=deepseek/deepseek-v4-pro

# CrofAI (クラウド)
CROFAI_BASE_URL=https://api.crofai.com
CROFAI_API_KEY=sk-your-key-here
CROFAI_MODEL=deepseek/deepseek-v4-pro

# 使用するプロバイダー: "opencode" | "crofai"
LLM_PROVIDER=opencode

# === Discord ===
DISCORD_TOKEN=your-discord-bot-token-here

# === Telegram ===
TELEGRAM_TOKEN=your-telegram-bot-token-here

# === SearXNG ===
SEARXNG_URL=http://localhost:18080

# === Agent Settings ===
MAX_ITERATIONS=20
MAX_HISTORY=100
DATA_DIR=./data

# === Platforms to start (comma-separated: discord,telegram) ===
ENABLED_PLATFORMS=discord,telegram
